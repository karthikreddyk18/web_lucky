        "def factorial(n):\n",
        "    result = 1\n",
        "    for i in range(1, n + 1):\n",
        "        result *= i\n",
        "    return result\n",
        "\n",
        "num = int(input(\"Enter a number: \"))\n",
        "if(num<0):\n",
        " print(\"Not defined\")\n",
        "else:\n",
        " print(\"Factorial:\", factorial(num))\n"
